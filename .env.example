TODOMATE_PORT="3000"

# Required for live Todomate/Firebase Auth REST calls.
# Firebase web API keys are public client config, but keep them out of source.
# TODOMATE_FIREBASE_API_KEY="paste-todomate-firebase-web-api-key-here"

# Required for API bearer sessions.
# Generate with: openssl rand -hex 32
# SESSION_ENCRYPTION_KEY="paste-64-hex-characters-here"
SESSION_TTL_DAYS="30"
CORS_ORIGIN="*"

# Defaults to disabled so public/server deployments cannot DM people by accident.
TODOMATE_ENABLE_SOCIAL_WRITES="false"
